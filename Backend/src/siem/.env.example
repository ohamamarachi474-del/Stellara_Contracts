# SIEM (Security Information and Event Management) Configuration

# Enable/Disable SIEM Module
SIEM_ENABLED=true

# Log Aggregation Settings
LOG_RETENTION_DAYS=365
LOG_BATCH_SIZE=1000
LOG_PROCESSING_WORKERS=4

# Threat Detection Settings
THREAT_DETECTION_ENABLED=true
ML_MODEL_PATH=./models/threat-classifier-v1
ML_CONFIDENCE_THRESHOLD=0.7
ANOMALY_DETECTION_ENABLED=true

# Incident Response Settings
INCIDENT_RESPONSE_ENABLED=true
AUTOMATED_RESPONSE_ENABLED=true
ESCALATION_ENABLED=true

# MITRE ATT&CK Framework
MITRE_MAPPING_ENABLED=true
MITRE_DATA_UPDATE_INTERVAL=3600

# Forensic Analysis Settings
FORENSIC_ENABLED=true
EVIDENCE_RETENTION_DAYS=2555
TIMELINE_RECONSTRUCTION_ENABLED=true

# External Integrations

# PagerDuty Integration
PAGERDUTY_ENABLED=false
PAGERDUTY_API_URL=https://api.pagerduty.com
PAGERDUTY_API_KEY=your_pagerduty_api_key
PAGERDUTY_SERVICE_ID=your_service_id
PAGERDUTY_COMPLIANCE_SERVICE_ID=your_compliance_service_id

# Slack Integration
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_CHANNEL=#security-alerts
SLACK_COMPLIANCE_CHANNEL=#compliance

# Splunk Integration
SPLUNK_ENABLED=false
SPLUNK_API_URL=https://your-splunk-instance.com:8088
SPLUNK_TOKEN=your_splunk_token
SPLUNK_INDEX=security

# Compliance Reporting Settings
COMPLIANCE_REPORTING_ENABLED=true
SOC2_REPORTING_ENABLED=true
ISO27001_REPORTING_ENABLED=true
COMPLIANCE_REPORT_SCHEDULE=0 0 1 * *  # Monthly at 00:00 on day 1

# Database Settings for SIEM
SIEM_DB_HOST=localhost
SIEM_DB_PORT=5432
SIEM_DB_USERNAME=siem_user
SIEM_DB_PASSWORD=siem_password
SIEM_DB_DATABASE=stellara_siem

# Redis Settings for SIEM
SIEM_REDIS_HOST=localhost
SIEM_REDIS_PORT=6379
SIEM_REDIS_PASSWORD=
SIEM_REDIS_DB=1

# File Storage for Evidence and Reports
SIEM_STORAGE_PATH=/var/lib/stellara/siem
EVIDENCE_STORAGE_PATH=/var/lib/stellara/siem/evidence
REPORT_STORAGE_PATH=/var/lib/stellara/siem/reports

# Security Settings
SIEM_ENCRYPTION_KEY=your_encryption_key_here
SIEM_HMAC_KEY=your_hmac_key_here
EVIDENCE_INTEGRITY_CHECK_ENABLED=true

# Performance Settings
SIEM_MAX_CONCURRENT_PROCESSES=10
SIEM_QUEUE_SIZE=10000
SIEM_PROCESSING_TIMEOUT=300000

# Monitoring and Health Checks
SIEM_HEALTH_CHECK_ENABLED=true
SIEM_METRICS_ENABLED=true
SIEM_PERFORMANCE_MONITORING_ENABLED=true

# API Rate Limiting for SIEM
SIEM_API_RATE_LIMIT=1000
SIEM_API_RATE_WINDOW=60

# Notification Settings
NOTIFICATION_RETRY_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY=5000
NOTIFICATION_TIMEOUT=30000

# Machine Learning Settings
ML_MODEL_UPDATE_INTERVAL=86400
ML_TRAINING_DATA_RETENTION_DAYS=90
ML_FEATURE_ENGINEERING_ENABLED=true

# Threat Intelligence Settings
THREAT_INTELLIGENCE_ENABLED=true
THREAT_INTEL_FEEDS=https://feed1.example.com,https://feed2.example.com
THREAT_INTEL_UPDATE_INTERVAL=3600

# Audit and Logging Settings
SIEM_AUDIT_LOG_ENABLED=true
SIEM_AUDIT_LOG_PATH=/var/log/stellara/siem-audit.log
SIEM_DEBUG_MODE=false

# Integration with Existing Systems
INTEGRATE_WITH_EXISTING_LOGGING=true
INTEGRATE_WITH_EXISTING_MONITORING=true
INTEGRATE_WITH_EXISTING_AUTH=true

# Webhook Settings
SIEM_WEBHOOK_ENABLED=true
SIEM_WEBHOOK_SECRET=your_webhook_secret
SIEM_WEBHOOK_URL=https://your-webhook-endpoint.com/siem

# Dashboard and Visualization
SIEM_DASHBOARD_ENABLED=true
SIEM_REAL_TIME_UPDATES=true
SIEM_DASHBOARD_REFRESH_INTERVAL=5000

# Data Privacy Settings
SIEM_DATA_ANONYMIZATION=false
SIEM_PII_DETECTION_ENABLED=true
SIEM_GDPR_COMPLIANCE_ENABLED=true
