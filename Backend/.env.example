# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=password
DATABASE_NAME=novafund
DATABASE_URL=postgresql://postgres:password@localhost:5432/novafund

# Shadow database (used by prisma migrate dev for drift detection)
SHADOW_DATABASE_URL=postgresql://postgres:password@localhost:5432/novafund_shadow

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET=your-access-token-secret-here
JWT_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-token-secret-here
JWT_REFRESH_EXPIRATION=7d

# Server Configuration
PORT=3000
API_PREFIX=api/v1
NODE_ENV=development

# Blue-Green Deployment Metadata
DEPLOYMENT_ENVIRONMENT=staging
DEPLOYMENT_SLOT=blue
ACTIVE_COLOR=blue
TRAFFIC_STATUS=warming
RELEASE_VERSION=local
RELEASE_COMMIT_SHA=local
RELEASE_BUILD_ID=manual

# Blue-Green Control Plane
BLUE_GREEN_ACTIVE_SLOT=blue
BLUE_GREEN_CANDIDATE_SLOT=green
BLUE_GREEN_PUBLIC_BASE_URL=https://api.example.com
BLUE_GREEN_BLUE_BASE_URL=https://blue.api.example.com
BLUE_GREEN_GREEN_BASE_URL=https://green.api.example.com
BLUE_GREEN_HEALTH_PATH=/health/ready
BLUE_GREEN_SMOKE_PATHS=/health,/health/ready
BLUE_GREEN_TRAFFIC_STEPS=10,50,100
BLUE_GREEN_STEP_INTERVAL_MS=15000
BLUE_GREEN_STEP_TIMEOUT_MS=120000
BLUE_GREEN_HEALTH_TIMEOUT_MS=120000
BLUE_GREEN_LB_SWITCH_URL=https://deploy-control.example.com/switch
# BLUE_GREEN_LB_STATUS_URL=https://deploy-control.example.com/status
# BLUE_GREEN_LB_API_TOKEN=
BLUE_GREEN_ROLLBACK_ON_FAILURE=true
BLUE_GREEN_RUN_DB_ROLLBACK=false

# Service Configuration
SERVICE_NAME=stellara-api

# Logging Configuration
LOG_LEVEL=info
LOG_PRETTY_PRINT=true
LOG_FORMAT=json
LOG_INCLUDE_CONTEXT=true

# External Logging (optional - for ELK, Datadog, New Relic)
# LOG_EXTERNAL_ENABLED=false
# LOG_EXTERNAL_TYPE=elk
# LOG_EXTERNAL_ENDPOINT=http://elasticsearch:9200
# LOG_EXTERNAL_API_KEY=your-api-key

# Stellar Blockchain Configuration
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contract IDs (replace with actual deployed contract addresses)
PROJECT_LAUNCH_CONTRACT_ID=CD...
ESCROW_CONTRACT_ID=CD...
PROFIT_DISTRIBUTION_CONTRACT_ID=CD...
SUBSCRIPTION_POOL_CONTRACT_ID=CD...
GOVERNANCE_CONTRACT_ID=CD...
REPUTATION_CONTRACT_ID=CD...

# Indexer Configuration
INDEXER_POLL_INTERVAL_MS=5000
INDEXER_REORG_DEPTH_THRESHOLD=5
INDEXER_MAX_EVENTS_PER_FETCH=100
INDEXER_RETRY_ATTEMPTS=3
INDEXER_RETRY_DELAY_MS=1000
# Optional: Start from specific ledger (for initial sync)
# INDEXER_START_LEDGER=1000000

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_ID_STARTER=price_...
STRIPE_PRICE_ID_PROFESSIONAL=price_...
STRIPE_PRICE_ID_ENTERPRISE=price_...
# =============================================================================
# AWS S3 Backup Configuration
# =============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Backup Bucket Configuration
S3_BACKUP_BUCKET=stellara-backups
S3_BACKUP_PREFIX=postgresql

# WAL Archiving Configuration
WAL_ARCHIVE_ENABLED=true
WAL_ARCHIVE_BUCKET=stellara-wal-archives
WAL_ARCHIVE_PREFIX=wal

# Backup Retention Policies
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_WEEKS=4
BACKUP_RETENTION_MONTHS=12

# Backup Schedule (cron format: daily at 2 AM)
BACKUP_SCHEDULE=0 2 * * *

# Backup Encryption (optional - uses AWS KMS if provided)
BACKUP_ENCRYPTION_KEY_ID=

# Backup Verification
BACKUP_VERIFY_AFTER_UPLOAD=true
BACKUP_VERIFY_SCHEDULE=0 3 * * *

# Disaster Recovery Settings
DR_RESTORE_TARGET_RTO_MINUTES=240
DR_RESTORE_TARGET_RPO_MINUTES=60
DR_TEST_SCHEDULE=0 0 1 */3 *

# Webhook Delivery
WEBHOOK_REQUEST_TIMEOUT_MS=10000
