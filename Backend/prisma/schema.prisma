  HOLD
}

// ─── Payment System Models ───────────────────────────────────────────────────

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  UNPAID
  TRIALING
  PAUSED
}

enum InvoiceStatus {
  DRAFT
  OPEN
  PAID
  UNCOLLECTIBLE
  VOID
}

enum PaymentEventType {
  SUBSCRIPTION_CREATED
  SUBSCRIPTION_UPDATED
  SUBSCRIPTION_CANCELLED
  INVOICE_CREATED
  INVOICE_PAID
  INVOICE_PAYMENT_FAILED
  PAYMENT_METHOD_ATTACHED
  PAYMENT_METHOD_DETACHED
  USAGE_RECORDED
  DUNNING_STARTED
  DUNNING_RESOLVED
  DUNNING_FAILED
}

model SubscriptionPlan {
  id            String   @id @default(uuid())
  name          String   @unique
  description   String?
  stripePriceId String   @unique @map("stripe_price_id")
  amount        Int // Amount in cents
  currency      String   @default("usd")
  interval      String   @default("month") // month, year
  features      Json? // Feature flags and limits
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                   String             @id @default(uuid())
  tenantId             String             @unique @map("tenant_id")
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  planId               String             @map("plan_id")
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  stripeCustomerId     String             @map("stripe_customer_id")
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodStart   DateTime           @map("current_period_start")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  canceledAt           DateTime?          @map("canceled_at")
  trialStart           DateTime?          @map("trial_start")
  trialEnd             DateTime?          @map("trial_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")

  invoices            Invoice[]
  usageRecords        UsageRecord[]
  paymentEvents       PaymentEvent[]
  dunningAttempts     DunningAttempt[]
  revenueRecognitions RevenueRecognition[]
  prorationAdjustments ProrationAdjustment[]
  billingCycleAnchor  DateTime?          @map("billing_cycle_anchor")

  @@index([tenantId])
  @@index([status])
  @@index([stripeCustomerId])
  @@map("subscriptions")
}

model RevenueRecognition {
  id             String       @id @default(uuid())
  subscriptionId String?      @map("subscription_id")
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  invoiceId      String?      @map("invoice_id")
  invoice        Invoice?     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  amount         Int
  currency       String       @default("usd")
  recognizedAt   DateTime     @map("recognized_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([subscriptionId])
  @@index([invoiceId])
  @@map("revenue_recognitions")
}

model ProrationAdjustment {
  id             String       @id @default(uuid())
  subscriptionId String       @map("subscription_id")
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount         Int
  description    String?
  appliedAt      DateTime     @map("applied_at")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([subscriptionId])
  @@map("proration_adjustments")
}

model UsageRecord {
  id                  String       @id @default(uuid())
  subscriptionId      String       @map("subscription_id")
  subscription        Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  tenantId            String       @map("tenant_id")
  metricName          String       @map("metric_name") // api_calls, storage_gb, compute_hours
  quantity            Int
  timestamp           DateTime     @default(now())
  stripeUsageRecordId String?      @map("stripe_usage_record_id")
  createdAt           DateTime     @default(now()) @map("created_at")

  @@index([subscriptionId])
  @@index([tenantId])
  @@index([metricName])
  @@index([timestamp])
  @@map("usage_records")
}

model Invoice {
  id               String        @id @default(uuid())
  subscriptionId   String        @map("subscription_id")
  subscription     Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  tenantId         String        @map("tenant_id")
  stripeInvoiceId  String        @unique @map("stripe_invoice_id")
  status           InvoiceStatus @default(DRAFT)
  amountDue        Int           @map("amount_due") // in cents
  amountPaid       Int           @default(0) @map("amount_paid")
  currency         String        @default("usd")
  pdfUrl           String?       @map("pdf_url")
  hostedInvoiceUrl String?       @map("hosted_invoice_url")
  invoiceNumber    String?       @map("invoice_number")
  dueDate          DateTime?     @map("due_date")
  paidAt           DateTime?     @map("paid_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  revenueRecognitions RevenueRecognition[]

  @@index([subscriptionId])
  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@map("invoices")
}

model SupplyChainFinanceInvoice {
  id                     String                            @id @default(cuid())
  tenantId               String?                           @map("tenant_id")
  sellerUserId           String                            @map("seller_user_id")
  buyerUserId            String?                           @map("buyer_user_id")
  invoiceNumber          String                            @map("invoice_number")
  debtorName             String                            @map("debtor_name")
  debtorEmail            String?                           @map("debtor_email")
  amount                 Decimal                           @db.Decimal(18, 2)
  currency               String                            @default("USD")
  issueDate              DateTime                          @map("issue_date")
  dueDate                DateTime                          @map("due_date")
  uploadedDocumentUrl    String                            @map("uploaded_document_url")
  documentHash           String?                           @map("document_hash")
  description            String?
  metadata               Json?
  status                 SupplyChainFinanceInvoiceStatus   @default(DRAFT)
  verificationStatus     SupplyChainVerificationStatus     @default(PENDING) @map("verification_status")
  buyerApprovalStatus    SupplyChainApprovalStatus         @default(PENDING) @map("buyer_approval_status")
  complianceStatus       SupplyChainComplianceStatus       @default(PENDING) @map("compliance_status")
  accountingProvider     SupplyChainAccountingProvider?    @map("accounting_provider")
  accountingReference    String?                           @map("accounting_reference")
  externalInvoiceId      String?                           @map("external_invoice_id")
  nftTokenId             String?                           @unique @map("nft_token_id")
  nftMetadataUri         String?                           @map("nft_metadata_uri")
  smartContractAddress   String?                           @map("smart_contract_address")
  riskScore              Int                               @default(50) @map("risk_score")
  riskGrade              SupplyChainRiskGrade              @default(C) @map("risk_grade")
  advanceRateBps         Int                               @default(8000) @map("advance_rate_bps")
  reserveAmount          Decimal                           @default(0) @db.Decimal(18, 2) @map("reserve_amount")
  financedAmount         Decimal                           @default(0) @db.Decimal(18, 2) @map("financed_amount")
  expectedYieldBps       Int                               @default(0) @map("expected_yield_bps")
  regulatoryFlags        Json?                             @map("regulatory_flags")
  verifiedAt             DateTime?                         @map("verified_at")
  approvedAt             DateTime?                         @map("approved_at")
  tokenizedAt            DateTime?                         @map("tokenized_at")
  fundedAt               DateTime?                         @map("funded_at")
  settledAt              DateTime?                         @map("settled_at")
  defaultedAt            DateTime?                         @map("defaulted_at")
  createdAt              DateTime                          @default(now()) @map("created_at")
  updatedAt              DateTime                          @updatedAt @map("updated_at")

  verifications          SupplyChainInvoiceVerification[]
  auctions               SupplyChainDiscountAuction[]
  waterfalls             SupplyChainPaymentWaterfall[]
  collections            SupplyChainCollectionCase[]

  @@unique([sellerUserId, invoiceNumber])
  @@index([tenantId, createdAt])
  @@index([sellerUserId, status])
  @@index([buyerUserId, buyerApprovalStatus])
  @@index([verificationStatus, complianceStatus])
  @@map("scf_invoices")
}

model SupplyChainInvoiceVerification {
  id                 String                         @id @default(cuid())
  invoiceId          String                         @map("invoice_id")
  invoice            SupplyChainFinanceInvoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  verificationType   SupplyChainVerificationType    @default(DOCUMENT_REVIEW) @map("verification_type")
  status             SupplyChainVerificationStatus  @default(PENDING)
  reviewerUserId     String?                        @map("reviewer_user_id")
  notes              String?
  verificationData   Json?                          @map("verification_data")
  createdAt          DateTime                       @default(now()) @map("created_at")
  updatedAt          DateTime                       @updatedAt @map("updated_at")

  @@index([invoiceId, status])
  @@map("scf_invoice_verifications")
}

model SupplyChainDiscountAuction {
  id                   String                           @id @default(cuid())
  invoiceId            String                           @map("invoice_id")
  invoice              SupplyChainFinanceInvoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  reserveDiscountBps   Int                              @default(1200) @map("reserve_discount_bps")
  minimumBidAmount     Decimal                          @db.Decimal(18, 2) @map("minimum_bid_amount")
  fundingTargetAmount  Decimal                          @db.Decimal(18, 2) @map("funding_target_amount")
  startsAt             DateTime                         @map("starts_at")
  endsAt               DateTime                         @map("ends_at")
  status               SupplyChainAuctionStatus         @default(DRAFT)
  winningBidId         String?                          @unique @map("winning_bid_id")
  createdAt            DateTime                         @default(now()) @map("created_at")
  updatedAt            DateTime                         @updatedAt @map("updated_at")

  bids                 SupplyChainAuctionBid[]           @relation("AuctionBids")
  winningBid           SupplyChainAuctionBid?           @relation("WinningAuctionBid", fields: [winningBidId], references: [id], onDelete: SetNull)
  waterfall            SupplyChainPaymentWaterfall?

  @@index([invoiceId, status])
  @@index([status, endsAt])
  @@map("scf_discount_auctions")
}

model SupplyChainAuctionBid {
  id                  String                         @id @default(cuid())
  auctionId           String                         @map("auction_id")
  auction             SupplyChainDiscountAuction     @relation("AuctionBids", fields: [auctionId], references: [id], onDelete: Cascade)
  investorUserId      String                         @map("investor_user_id")
  investorWallet      String?                        @map("investor_wallet")
  discountRateBps     Int                            @map("discount_rate_bps")
  bidAmount           Decimal                        @db.Decimal(18, 2) @map("bid_amount")
  expectedYieldBps    Int                            @map("expected_yield_bps")
  status              SupplyChainBidStatus           @default(ACTIVE)
  metadata            Json?
  createdAt           DateTime                       @default(now()) @map("created_at")
  updatedAt           DateTime                       @updatedAt @map("updated_at")

  winningAuction      SupplyChainDiscountAuction?    @relation("WinningAuctionBid")

  @@index([auctionId, status])
  @@index([investorUserId, createdAt])
  @@map("scf_auction_bids")
}

model SupplyChainPaymentWaterfall {
  id                        String                              @id @default(cuid())
  invoiceId                 String                              @map("invoice_id")
  invoice                   SupplyChainFinanceInvoice           @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  auctionId                 String?                             @unique @map("auction_id")
