  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@unique([key, scope, tenantId, userId])
  @@index([scope, tenantId])
  @@index([key])
  @@map("config_entries")
}

model FeatureFlag {
  id         String   @id @default(uuid())
  key        String
  enabled    Boolean  @default(false)
  tenantId   String?  @map("tenant_id")
  rolloutPct Int      @default(100) @map("rollout_pct")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@unique([key, tenantId])
  @@index([key])
  @@index([tenantId])
  @@map("feature_flags")
}

model Experiment {
  id              String      @id @default(uuid())
  name            String
  description     String?
  key             String      @unique
  status          ExperimentStatus @default(DRAFT)
  trafficCoverage Int         @default(100) @map("traffic_coverage")
  controlSize     Int         @default(50) @map("control_size")
  startDate       DateTime?   @map("start_date")
  endDate         DateTime?   @map("end_date")
  metricName      String      @map("metric_name")
  metadata        Json?
  tenantId        String?     @map("tenant_id")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  assignments     ExperimentAssignment[]
  events          ExperimentEvent[]

  @@index([key])
  @@index([tenantId])
  @@map("experiments")
}

enum ExperimentStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

model ExperimentAssignment {
  id           String     @id @default(uuid())
  experimentId String     @map("experiment_id")
  userId       String     @map("user_id")
  variant      ExperimentVariant
  assignedAt   DateTime   @default(now()) @map("assigned_at")

  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([experimentId, userId])
  @@index([userId])
  @@map("experiment_assignments")
}

enum ExperimentVariant {
  CONTROL
  TREATMENT
}

model ExperimentEvent {
  id           String   @id @default(uuid())
  experimentId String   @map("experiment_id")
  userId       String   @map("user_id")
  eventName    String   @map("event_name")
  value        Float?   @default(1.0)
  metadata     Json?
  timestamp    DateTime @default(now())

  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId, eventName])
  @@index([userId])
  @@map("experiment_events")
}

model ConfigAuditLog {
  id        String      @id @default(uuid())
  key       String
  oldValue  String?     @map("old_value")
  newValue  String?     @map("new_value")
  scope     ConfigScope
  tenantId  String?     @map("tenant_id")
  actorId   String?     @map("actor_id")
  action    String // SET, DELETE, ROTATE_SECRET
  createdAt DateTime    @default(now()) @map("created_at")

  @@index([key])
  @@index([tenantId])
  @@index([createdAt])
  @@map("config_audit_logs")
}

model WebhookSubscription {
  id              String                    @id @default(uuid())
  tenantId        String?                   @map("tenant_id")
  name            String
  description     String?
  url             String
  secret          String
  status          WebhookSubscriptionStatus @default(ACTIVE)
  eventFilters    Json                      @map("event_filters")
  payloadFields   Json?                     @map("payload_fields")
  customHeaders   Json?                     @map("custom_headers")
  createdBy       String?                   @map("created_by")
  lastTriggeredAt DateTime?                 @map("last_triggered_at")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @updatedAt @map("updated_at")

  tenant     Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  deliveries WebhookDelivery[]

  @@index([tenantId, status])
  @@index([status])
  @@map("webhook_subscriptions")
}

model WebhookEvent {
  id         String   @id @default(uuid())
  tenantId   String?  @map("tenant_id")
  eventType  String   @map("event_type")
  source     String   @default("platform")
  payload    Json
  metadata   Json?
  occurredAt DateTime @default(now()) @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant     Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  deliveries WebhookDelivery[]

  @@index([tenantId, eventType])
  @@index([eventType, occurredAt])
  @@map("webhook_events")
}

model WebhookDelivery {
  id               String                @id @default(uuid())
  subscriptionId   String                @map("subscription_id")
  eventId          String                @map("event_id")
  status           WebhookDeliveryStatus @default(PENDING)
  attempts         Int                   @default(0)
  maxAttempts      Int                   @default(10) @map("max_attempts")
  nextAttemptAt    DateTime              @default(now()) @map("next_attempt_at")
  lastAttemptAt    DateTime?             @map("last_attempt_at")
  deliveredAt      DateTime?             @map("delivered_at")
  lastResponseCode Int?                  @map("last_response_code")
  lastResponseBody String?               @map("last_response_body")
  errorMessage     String?               @map("error_message")
  signature        String?               @map("signature")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  event        WebhookEvent        @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([subscriptionId, status])
  @@index([eventId])
  @@map("webhook_deliveries")
}

enum ConfigScope {
  GLOBAL
  TENANT
  USER
}

model AuditLog {
  id            String      @id @default(uuid())
  correlationId String?     @map("correlation_id")
  tenantId      String?     @map("tenant_id")
  userId        String?     @map("user_id")
  action        AuditAction
  entityType    String      @map("entity_type")
  entityId      String?     @map("entity_id")
  method        String? // HTTP method (GET, POST, PUT, DELETE)
  path          String? // Request path
  statusCode    Int?        @map("status_code")
  ipAddress     String?     @map("ip_address")
  userAgent     String?     @map("user_agent")
  requestBody   Json?       @map("request_body")
  responseBody  Json?       @map("response_body")
  previousState Json?       @map("previous_state")
  newState      Json?       @map("new_state")
  changedFields String[]    @map("changed_fields")
  metadata      Json?
  duration      Int? // Duration in milliseconds
  errorMessage  String?     @map("error_message")
  checksum      String? // SHA-256 hash for tamper detection
  createdAt     DateTime    @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@index([correlationId])
  @@index([createdAt])
  @@index([statusCode])
  @@map("audit_logs")
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  SYSTEM_EVENT
  API_CALL
  ERROR
  ACCESS_DENIED
  DATA_CHANGE
}

model AuditRetentionPolicy {
  id              String    @id @default(uuid())
  name            String    @unique
  tenantId        String?   @map("tenant_id")
  retentionDays   Int       @default(90) @map("retention_days")
  entityTypes     String[]  @map("entity_types")
  actions         String[] // AuditAction values to apply policy to
  archiveEnabled  Boolean   @default(false) @map("archive_enabled")
  archiveLocation String?   @map("archive_location")
  isActive        Boolean   @default(true) @map("is_active")
  lastExecutedAt  DateTime? @map("last_executed_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([isActive])
  @@map("audit_retention_policies")
}

model SentimentRecord {
