  userAgent   String?  @map("user_agent")
  referer     String?
  country     String?
  city        String?
  device      String?
  browser     String?
  os          String?
  timestamp   DateTime @default(now())
  converted   Boolean  @default(false)
  fraudScore  Decimal  @default(0) @db.Decimal(5, 4) @map("fraud_score")
  metadata    Json?

  @@index([referralLinkId])
  @@index([ipAddress])
  @@index([timestamp])
  @@index([converted])
  @@map("referral_clicks")
}

model ReferralSignup {
  id          String   @id @default(cuid())
  referralLinkId String @map("referral_link_id")
  referralLink ReferralLink @relation(fields: [referralLinkId], references: [id], onDelete: Cascade)
