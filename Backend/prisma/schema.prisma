  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relations
  referralLinks     ReferralLink[]
  commissions       Commission[]
  payouts           Payout[]
  performanceMetrics AffiliatePerformanceMetric[]
  fraudFlags        AffiliateFraudFlag[]
  externalAffiliateAccounts ExternalAffiliateAccount[]

  @@index([userId])
  @@index([referralCode])
  @@index([status])
  @@index([tier])
  @@map("affiliates")
}

model ReferralLink {
  id          String   @id @default(cuid())
  affiliateId String   @map("affiliate_id")
