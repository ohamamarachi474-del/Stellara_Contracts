  name        String?
  description String?
  destinationUrl String? @map("destination_url")
  campaignId  String?  @map("campaign_id")
  isActive    Boolean  @default(true) @map("is_active")
  clickCount  Int      @default(0) @map("click_count")
  signupCount Int      @default(0) @map("signup_count")
  conversionCount Int  @default(0) @map("conversion_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  clicks      ReferralClick[]
  signups     ReferralSignup[]
  conversions ReferralConversion[]

  @@index([affiliateId])
  @@index([code])
  @@index([isActive])
  @@map("referral_links")
}

model ReferralClick {
  id          String   @id @default(cuid())
  referralLinkId String @map("referral_link_id")
  referralLink ReferralLink @relation(fields: [referralLinkId], references: [id], onDelete: Cascade)
