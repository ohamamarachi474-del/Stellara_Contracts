  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([affiliateId])
  @@index([referralConversionId])
  @@index([status])
  @@index([tier])
  @@index([calculatedAt])
  @@map("commissions")
