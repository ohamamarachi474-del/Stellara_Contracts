// ─── Predictive Settlement Engine ───────────────────────────────────────────

model NetworkCongestionSnapshot {
  id                  String   @id @default(cuid())
  network             String   @default("stellar")
  ledgerSeq           Int?     @map("ledger_seq")
  baseFeeStroops      Int      @map("base_fee_stroops")
  priorityFeeStroops  Int      @default(0) @map("priority_fee_stroops")
  txVolumePerLedger   Int      @map("tx_volume_per_ledger")
  ledgerCloseTimeMs   Int      @map("ledger_close_time_ms")
  congestionScore     Float    @map("congestion_score")        // 0.0–1.0
  predictedScoreP5m   Float?   @map("predicted_score_p5m")    // 5-min forecast
  predictedScoreP10m  Float?   @map("predicted_score_p10m")   // 10-min forecast
  predictedScoreP15m  Float?   @map("predicted_score_p15m")   // 15-min forecast
  predictedFeeP5m     Int?     @map("predicted_fee_p5m")      // stroops
  predictedFeeP10m    Int?     @map("predicted_fee_p10m")
  predictedFeeP15m    Int?     @map("predicted_fee_p15m")
  p95FeeThreshold     Int?     @map("p95_fee_threshold")
  recordedAt          DateTime @default(now()) @map("recorded_at")

  @@index([network, recordedAt])
  @@index([recordedAt])
  @@map("network_congestion_snapshots")
}

model SettlementJob {
  id                 String              @id @default(cuid())
  idempotencyKey     String              @unique @map("idempotency_key")
  settlementType     String              @map("settlement_type")   // e.g. "clearing", "claim", "swap"
  signerAddress      String              @map("signer_address")
  contractAddress    String?             @map("contract_address")
  payload            Json
  urgency            SettlementUrgency   @default(NORMAL)
  status             SettlementJobStatus @default(QUEUED)
  priority           Int                 @default(50)              // 0–100 computed score
  deadlineAt         DateTime?           @map("deadline_at")       // SLA deadline
  slaMinutes         Int                 @default(60) @map("sla_minutes")
  scheduledAt        DateTime?           @map("scheduled_at")      // optimal submission time
  submittedAt        DateTime?           @map("submitted_at")
  confirmedAt        DateTime?           @map("confirmed_at")
  txHash             String?             @map("tx_hash")
  feePaidStroops     Int?                @map("fee_paid_stroops")
  estimatedFeeSaved  Int?                @map("estimated_fee_saved")
  l2Provider         String?             @map("l2_provider")       // null = L1
  congestionAtSubmit Float?              @map("congestion_at_submit")
  failureReason      String?             @map("failure_reason")
  attempts           Int                 @default(0)
  maxAttempts        Int                 @default(5) @map("max_attempts")
  metadata           Json?
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  slaRecord          SettlementSlaRecord?

  @@index([status, scheduledAt])
  @@index([urgency, status])
  @@index([signerAddress, status])
  @@index([createdAt])
  @@map("settlement_jobs")
}

model SettlementCostSaving {
  id               String   @id @default(cuid())
  settlementJobId  String?  @map("settlement_job_id")
  network          String   @default("stellar")
  feePaidStroops   Int      @map("fee_paid_stroops")
  baselineFeeStroops Int    @map("baseline_fee_stroops")     // fee that would have been paid without optimization
  savedStroops     Int      @map("saved_stroops")
  savedUsd         Float?   @map("saved_usd")
  strategy         String                                    // e.g. "deferred", "l2_offload", "batch"
  recordedAt       DateTime @default(now()) @map("recorded_at")

  @@index([recordedAt])
  @@index([network, recordedAt])
  @@map("settlement_cost_savings")
}

model SettlementSlaRecord {
  id                 String   @id @default(cuid())
  settlementJobId    String   @unique @map("settlement_job_id")
  job                SettlementJob @relation(fields: [settlementJobId], references: [id], onDelete: Cascade)
  slaMinutes         Int      @map("sla_minutes")
  deadlineAt         DateTime @map("deadline_at")
  confirmedAt        DateTime? @map("confirmed_at")
  actualMinutes      Float?   @map("actual_minutes")
  slaBreached        Boolean  @default(false) @map("sla_breached")
  breachMarginMinutes Float?  @map("breach_margin_minutes")  // negative = breached by N minutes
  urgency            SettlementUrgency
  recordedAt         DateTime @default(now()) @map("recorded_at")

  @@index([slaBreached, recordedAt])
  @@index([urgency, slaBreached])
  @@map("settlement_sla_records")
}

enum SettlementUrgency {
  LOW
  NORMAL
  HIGH
  URGENT   // >95th percentile priority
}

enum SettlementJobStatus {
  QUEUED
  SCHEDULED
  PROCESSING
  SUBMITTED
  CONFIRMED
  FAILED
  CANCELLED
}

// ─── Universal Cross-Chain Router Models ──────────────────────────────────────

enum SupportedBlockchain {
  ETHEREUM
  STELLAR
  SOLANA
  COSMOS
  POLKADOT
  AVALANCHE
  ARBITRUM
  OPTIMISM
  POLYGON
  BASE
}

enum MessageStatus {
  INITIATED
  LOCKED
  VERIFIED
  MINTED
  BURNED
  RELEASED
  SLASHED
  FAILED
  REVERTED
}

enum RouterEventType {
  MESSAGE_INITIATED
  FINALITY_DETECTED
  LIGHT_CLIENT_UPDATE
  VALIDATOR_SLASH
  ASSET_LOCKED
  ASSET_RELEASED
  VERIFICATION_SUCCESS
  VERIFICATION_FAILED
}

enum ValidatorStatus {
  ACTIVE
  INACTIVE
  SLASHED
  EXITED
}

model ChainAdapter {
  id                    String   @id @default(cuid())
  blockchain            SupportedBlockchain @unique
  rpcEndpoint           String   @map("rpc_endpoint")
  wsEndpoint            String?  @map("ws_endpoint")
  chainId               String   @unique @map("chain_id")
  explorerUrl           String?  @map("explorer_url")
  isActive              Boolean  @default(true) @map("is_active")
  finalityBlocks        Int      @default(12) @map("finality_blocks") // blocks until finality
  avgBlockTime          Int      @default(12000) @map("avg_block_time") // ms
  maxMessageSize        Int      @default(1024) @map("max_message_size")
  messageGasLimit       String   @default("500000") @map("message_gas_limit")
  heartbeatInterval     Int      @default(30000) @map("heartbeat_interval") // ms
  lastHeartbeat         DateTime? @map("last_heartbeat")
  isHealthy             Boolean  @default(true) @map("is_healthy")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  lightClients          LightClient[]
  validators            Validator[]
  messages              CrossChainMessage[]
  bridgedAssets         BridgedAsset[]

  @@map("chain_adapters")
}

model LightClient {
  id                    String   @id @default(cuid())
  chainId               String   @map("chain_id")
  chainAdapter          ChainAdapter @relation(fields: [chainId], references: [chainId])
  latestBlockNumber     BigInt   @map("latest_block_number")
  latestBlockHash       String   @map("latest_block_hash")
  latestBlockTime       DateTime @map("latest_block_time")
  commitmentRoot        String   @map("commitment_root")
  validatorSetRoot      String   @map("validator_set_root")
  trustedBlockNumber    BigInt   @map("trusted_block_number")
  verificationCount     Int      @default(0) @map("verification_count")
  failureCount          Int      @default(0) @map("failure_count")
  lastUpdateTime        DateTime @default(now()) @map("last_update_time")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  headerProofs          HeaderProof[]

  @@unique([chainId])
  @@index([chainId])
  @@map("light_clients")
}

model HeaderProof {
  id                    String   @id @default(cuid())
  lightClientId         String   @map("light_client_id")
  lightClient           LightClient @relation(fields: [lightClientId], references: [id])
  blockNumber           BigInt   @map("block_number")
  blockHash             String   @map("block_hash")
  proof                 String   @db.Text // Merkle proof or light client proof
  signerBitmap          String   @map("signer_bitmap") // bitmap of signing validators
  threshold             Int      // number of validators that must sign
  isVerified            Boolean  @default(false) @map("is_verified")
  verificationTime      DateTime? @map("verification_time")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([lightClientId])
  @@index([blockNumber])
  @@map("header_proofs")
}

model CrossChainMessage {
  id                    String   @id @default(cuid())
  messageId             String   @unique @map("message_id") // Global message ID
  sourceChain           String   @map("source_chain")
  sourceAdapter         ChainAdapter @relation(fields: [sourceChain], references: [chainId])
  destChain             String   @map("dest_chain")
  senderAddress         String   @map("sender_address")
  recipientAddress      String   @map("recipient_address")
  messagePayload        String   @db.Text @map("message_payload") // JSON encoded
  messageHash           String   @unique @map("message_hash")
  status                MessageStatus @default(INITIATED)
  nonce                 BigInt   // for ordering
  sequenceNumber        BigInt   @map("sequence_number")
  
  // Lock-and-mint / burn-and-release tracking
  assetSymbol           String?  @map("asset_symbol")
  assetAmount           Decimal? @db.Decimal(36, 18) @map("asset_amount")
  lockTxHash            String?  @map("lock_tx_hash")
  releaseTxHash         String?  @map("release_tx_hash")
  
  // Execution tracking
  gasUsed               Decimal? @db.Decimal(36, 18) @map("gas_used")
  executionTime         Int?     @map("execution_time") // ms
  errorMessage          String?  @map("error_message")
  
  // Support for arbitrary contract calls
  contractAddress       String?  @map("contract_address")
  functionSelector      String?  @map("function_selector")
  functionArgs          String?  @db.Text @map("function_args") // JSON
  
  // Finality tracking
  sourceFinalized       Boolean  @default(false) @map("source_finalized")
  destFinalized         Boolean  @default(false) @map("dest_finalized")
  sourceFinalizationBlockNumber BigInt? @map("source_finalization_block_number")
  destFinalizationBlockNumber   BigInt? @map("dest_finalization_block_number")
  
  initiatedAt           DateTime @default(now()) @map("initiated_at")
  lockedAt              DateTime? @map("locked_at")
  verifiedAt            DateTime? @map("verified_at")
  finalizedAt           DateTime? @map("finalized_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  receipts              MessageReceipt[]
  routerEvents          RouterEvent[]

  @@unique([sourceChain, destChain, messageId])
  @@index([status])
  @@index([sourceChain])
  @@index([destChain])
  @@index([senderAddress])
  @@index([createdAt])
  @@map("cross_chain_messages")
}

model MessageReceipt {
  id                    String   @id @default(cuid())
  messageId             String   @map("message_id")
  message               CrossChainMessage @relation(fields: [messageId], references: [id])
  chainId               String   @map("chain_id")
  blockNumber           BigInt   @map("block_number")
  blockHash             String   @map("block_hash")
  transactionHash       String   @unique @map("transaction_hash")
  logIndex              Int      @map("log_index")
  isConfirmed           Boolean  @default(false) @map("is_confirmed")
  confirmationCount     Int      @default(0) @map("confirmation_count")
  createdAt             DateTime @default(now()) @map("created_at")

  @@unique([messageId, chainId])
  @@index([messageId])
  @@index([chainId])
  @@map("message_receipts")
}

model Validator {
  id                    String   @id @default(cuid())
  validatorAddress      String   @map("validator_address")
  chainId               String   @map("chain_id")
  chainAdapter          ChainAdapter @relation(fields: [chainId], references: [chainId])
  stakedAmount          Decimal  @db.Decimal(36, 18) @map("staked_amount")
  totalSlashed          Decimal  @default(0) @db.Decimal(36, 18) @map("total_slashed")
  status                ValidatorStatus @default(ACTIVE)
  joinedAt              DateTime @map("joined_at")
  exitAmount            Decimal? @db.Decimal(36, 18) @map("exit_amount")
  exitAt                DateTime? @map("exit_at")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  slashings             SlashingEvent[]

  @@unique([chainId, validatorAddress])
  @@index([chainId])
  @@index([status])
  @@map("validators")
}

model SlashingEvent {
  id                    String   @id @default(cuid())
  validatorId           String   @map("validator_id")
  validator             Validator @relation(fields: [validatorId], references: [id])
  slashAmount           Decimal  @db.Decimal(36, 18) @map("slash_amount")
  reason                String   // e.g., "double_sign", "missed_attestation", "equivocation"
  slashPercentage       Decimal  @db.Decimal(5, 2) @map("slash_percentage") // e.g., 10.5 for 10.5%
  txHash                String?  @unique @map("tx_hash")
  blockNumber           BigInt?  @map("block_number")
  isExecuted            Boolean  @default(false) @map("is_executed")
  executedAt            DateTime? @map("executed_at")
  createdAt             DateTime @default(now()) @map("created_at")

  @@index([validatorId])
  @@index([createdAt])
  @@map("slashing_events")
